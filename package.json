{
  "name": "chatbot",
  "version": "1.0.0",
  "main": "chatbot.js",
  "scripts": {
    "start": "node chatbot.js",
    "dev": "NODE_ENV=development node chatbot.js",
    "build": "npm install --omit=dev",
    "fix-deps": "npm audit fix --force",
    "test": "echo \"Error: no test specified\" && exit 1",
    "railway:build": "npm install --omit=dev && npm rebuild",
    "docker:build": "docker build -t whatsapp-bot .",
    "docker:run": "docker run -it whatsapp-bot",
    "postinstall": "node node_modules/puppeteer/install.js"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "moment-timezone": "^0.6.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-extra-plugin-user-data-dir": "^2.4.1",
    "puppeteer-extra-plugin-user-preferences": "^2.4.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.31.0"
  },
  "engines": {
    "node": ">=18.x",
    "npm": ">=8.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davy7x/testechatbot.git"
  },
  "bugs": {
    "url": "https://github.com/davy7x/testechatbot/issues"
  },
  "homepage": "https://github.com/davy7x/testechatbot#readme",
  "devDependencies": {
    "@nesk/puphpeteer": "^2.0.0",
    "puppeteer": "^24.15.0"
  }
}
